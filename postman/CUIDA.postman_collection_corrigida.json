  "item": [
    {
      "name": "CT-API-01 - Cadastro de usuário",
      "item": [
        {
          "name": "CT-API-01.1 - Cadastro com dados válidos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Ana Paula\",\n  \"email\": \"ana@email.com\",\n  \"senha\": \"12345678\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/api/usuarios",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "usuarios"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status deve ser 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Mensagem deve ser: Usuário cadastrado com sucesso\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.message).to.eql(\"Usuário cadastrado com sucesso\");",
                  "});"
                ]
              }
            }
          ]
        },
