      "name": "CT-API-LOGIN - Login",
      "item": [
        {
          "name": "Login válido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"familiar@email.com\",\n  \"senha\": \"12345678\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/api/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status deve ser 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Mensagem deve ser: Login realizado com sucesso\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.message).to.eql(\"Login realizado com sucesso\");",
                  "});"
                ]
              }
            }
          ]
        },
